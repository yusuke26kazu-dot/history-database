{
  "name": "history-database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0",
    "build": "tsc && vite build && node scripts/inline-dist.mjs",
    "export": "npm run build && mkdir -p publish && cp dist/index.html publish/index.html",
    "open:local": "npm run dev",
    "preview": "vite preview",
    "preview:host": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@netlify/blobs": "^9.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
